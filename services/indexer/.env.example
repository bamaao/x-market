SUI_RPC_URL_FALLBACK=
X_MARKET_PACKAGE_ID=0x2e368e00532771eedd2df288bd61b0cb2324471b9fc6e14160a7f3079310ae6e
PROPHET_REGISTRY_ID=0xfa8359d6e1693542ef315eeda6a5c6c659dc819683a7bf86ac3391d1c4f63f38
ORACLE_CONFIG_ID=0x1ad185d06bcbb53a98c5a834516da7a28c748f32079faa8ff310a35d04f663d8
SEED_DEPLOY_JSON=../../deploy/testnet-v2.json
INDEXER_DATABASE_URL=postgresql://xmarket:xmarket@localhost:5432/xmarket_indexer
INDEXER_API_PORT=8800
INDEXER_EVENT_POLL_MS=15000
INDEXER_SNAPSHOT_POLL_MS=60000
INDEXER_STATS_POLL_MS=120000
INDEXER_CORS_ORIGIN=http://localhost:3000
# P3 市场元数据注册（留空则公开 POST /v1/markets/register）
# MARKET_REGISTER_SECRET=
# 市场封面持久化目录（INDEXER_COVER_STORAGE=local 时使用）
# INDEXER_COVERS_DIR=data/covers
# 封面存储：local（Indexer 磁盘）| ipfs（Pin 到 IPFS，image_url=ipfs://CID）
# INDEXER_COVER_STORAGE=local
# Prophet blob 持久化目录（INDEXER_PROPHET_STORAGE=local 时使用）
# INDEXER_PROPHET_BLOBS_DIR=data/prophecy-blobs
# Prophet blob 存储：local | ipfs（链上 blob_id=idx:… 或 ipfs:…）
# INDEXER_PROPHET_STORAGE=local
# IPFS Pin（INDEXER_COVER_STORAGE=ipfs 或 INDEXER_PROPHET_STORAGE=ipfs 时生效）
# IPFS_PIN_PROVIDER=pinata
# IPFS_PINATA_JWT=
# IPFS_KUBO_API_URL=http://127.0.0.1:5001
HOST=0.0.0.0
