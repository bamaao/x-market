# Sui 网络
SUI_NETWORK=testnet

# Sui RPC（Keeper 需稳定读池状态）
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# 已发布包 ID（与 app NEXT_PUBLIC_PACKAGE_ID 一致）
X_MARKET_PACKAGE_ID=0x2e368e00532771eedd2df288bd61b0cb2324471b9fc6e14160a7f3079310ae6e

# 池子 authority 私钥（须与 MarketPool.authority 一致，用于 set_lp_guard_params）
LP_GUARD_KEEPER_SECRET_KEY=suiprivkey...

# 逗号分隔的 Trading 池对象 ID
LP_GUARD_POOL_IDS=0xpool1,0xpool2

# 轮询间隔（毫秒）
LP_GUARD_POLL_MS=30000

# 风险窗口样本数（poll 次数）；30s × 10 ≈ 5 分钟
LP_GUARD_WINDOW_SAMPLES=10

# 有效费率上限（bps）；800 = 8%
LP_GUARD_MAX_EFFECTIVE_FEE_BPS=800

# 费率乘数上限（u16）；30000 ≈ 基础 200bps 拉到 800bps
LP_GUARD_MAX_FEE_MULTIPLIER_BPS=30000

# 虚拟 σ / 浓度上限
LP_GUARD_MAX_SIGMA_VIRTUAL_TENTHS=20
LP_GUARD_MAX_CONCENTRATION_VIRTUAL=50

# 无风险时乘数衰减系数（每 tick）
LP_GUARD_DECAY_FACTOR=0.85

# 触发更新的最小乘数变化（bps），避免频繁发 tx
LP_GUARD_UPDATE_THRESHOLD_BPS=200

# true = 只打日志不发链上交易
LP_GUARD_DRY_RUN=true

# 健康检查端口（GET /health）
LP_GUARD_HEALTH_PORT=8788

# 生产模式：DRY_RUN=false 且余额不足时拒绝启动
# LP_GUARD_PRODUCTION=true
