# 网络：testnet | mainnet
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# 已发布包 ID（生产必须设置；与 app NEXT_PUBLIC_PACKAGE_ID 一致）
PACKAGE_ID=0x2e368e00532771eedd2df288bd61b0cb2324471b9fc6e14160a7f3079310ae6e

# Gas Payer 私钥（suiprivkey... 或 base64 secret）
GAS_PAYER_PRIVATE_KEY=suiprivkey...

# 服务端口
PORT=8787

# 生产：设为 true 并配置明确 CORS（禁止 *）
# GAS_STATION_PRODUCTION=true
# NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# 每地址每分钟赞助上限
SPONSOR_RATE_LIMIT_PER_MIN=30

# Gas 余额低于此值时 /health 返回 ok:false（默认 0.5 SUI）
GAS_MIN_BALANCE_MIST=500000000
GAS_BALANCE_CHECK_MS=300000
SUI_RPC_URL_FALLBACK=
ALERT_WEBHOOK_URL=
